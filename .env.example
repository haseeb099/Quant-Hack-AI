# QuantAI Environment Variables



# LLM — Doubleword primary, Groq fallback; Anthropic opt-in for MetaOrchestrator
# Set QUANTAI_LLM_ALLOW_ANTHROPIC=true to enable Claude in the provider chain.

DOUBLEWORD_API_KEY=
DOUBLEWORD_MODEL=openai/gpt-oss-20b
DOUBLEWORD_MODEL_COMPLEX=openai/gpt-oss-120b
COPILOT_DOUBLEWORD_MODEL=openai/gpt-oss-20b
SENTIMENT_DOUBLEWORD_MODEL=google/gemma-4-31B-it
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (MetaOrchestrator) — model id only; not a Doubleword model name
ANTHROPIC_API_KEY=
META_ORCHESTRATOR_MODEL=claude-sonnet-4-6
QUANTAI_LLM_ALLOW_ANTHROPIC=false

# Per-role provider overrides (optional; default follows QUANTAI_LLM_PROVIDER)
SENTIMENT_LLM_PROVIDER=doubleword
ORCHESTRATOR_LLM_PROVIDER=doubleword
# Provider chain: auto | doubleword | groq | anthropic (anthropic requires QUANTAI_LLM_ALLOW_ANTHROPIC=true)
QUANTAI_LLM_PROVIDER=doubleword

# Orchestrator cost controls
META_ORCHESTRATOR_AI_ON_CONFLICT_ONLY=false
META_ORCHESTRATOR_COOLDOWN_MINUTES=10
# Use DOUBLEWORD_MODEL_COMPLEX (120b) only when explicitly enabled
META_ORCHESTRATOR_COMPLEX_MODEL=false



# ML signal model path (trained by scripts/train_signal_model.py)

ML_SIGNAL_MODEL_PATH=data/models/signal_model.pkl



# Pydantic Logfire — full pipeline tracing ($50 hackathon credits)

# Redeem: https://pydantic.dev/hackathon → https://logfire.pydantic.dev → Write token

LOGFIRE_TOKEN=

# Optional read token for Logfire MCP (defaults to LOGFIRE_TOKEN via scripts/run_logfire_mcp.py)

LOGFIRE_READ_TOKEN=

# EU projects: https://logfire-eu.pydantic.dev

LOGFIRE_BASE_URL=https://logfire-eu.pydantic.dev



# Doubleword inference routing (https://api.doubleword.ai/v1)
# Copilot may also use PYDANTIC_AI_GATEWAY_API_KEY below instead of a direct key.

# Cost controls (Copilot + sentiment)
COPILOT_USE_LLM=false
SENTIMENT_LLM_ENABLED=true
SENTIMENT_LEXICON_FIRST=false



# Logfire Gateway (optional Copilot path when no direct Doubleword key)

PYDANTIC_AI_GATEWAY_API_KEY=

COPILOT_GATEWAY_MODEL=gateway/openai:gpt-4o-mini



# Competition phase — use 'auto' to follow BST round schedule (recommended)

QUANTAI_PHASE=auto



# Runtime environment — set production on Northflank public ingress

QUANTAI_ENV=development



# MT5 account (MCP server + Python API testing)

# Log into MT5 manually first. MT5_SERVER must match the server name shown in MT5

# (File -> Login to Trade Account), not the IP address unless MT5 shows it that way.

MT5_LOGIN=

MT5_PASSWORD=

MT5_SERVER=

MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe



# MT5 bridge selection: auto | zmq | direct

# auto = ZeroMQ EA first, fall back to MetaTrader5 Python API (Windows)

MT5_BRIDGE=auto



# MT5 ZeroMQ bridge (live trading)

ZMQ_HOST=127.0.0.1

ZMQ_COMMAND_PORT=32768

ZMQ_CONFIRM_PORT=32769

ZMQ_TICK_PORT=32770

# Optional ZMQ tuning (factory sets defaults for auto mode)

ZMQ_VERIFY_RETRIES=3

ZMQ_WARMUP_SEC=2.0



# Dashboard (optional — Northflank sidecar)

# Required in production (QUANTAI_ENV=production) — generate a strong random token

DASHBOARD_AUTH_TOKEN=

# Baked into SPA at build time (Dockerfile.dashboard ARG) — must match DASHBOARD_AUTH_TOKEN

VITE_DASHBOARD_AUTH_TOKEN=

# Comma-separated allowed origins in production (empty = same-origin only)

DASHBOARD_CORS_ORIGINS=

DASHBOARD_PORT=8080

# Force demo badge when API runs without engine (browser/cloud dev)

DEMO_MODE=false



# Notion sync (optional — auto-enables when API key + database IDs are set)

NOTION_API_KEY=

NOTION_TRADE_JOURNAL_DS_ID=

NOTION_AGENT_PERF_DS_ID=

NOTION_RISK_EVENTS_DS_ID=

NOTION_TASKS_DS_ID=

# Optional: Notion page ID for full A–Z guide (blocks appended to this page)

NOTION_AZ_PAGE_ID=

# Set to false to disable; leave empty or true to auto-enable when configured

NOTION_SYNC_ENABLED=



# Market intelligence layer

INTELLIGENCE_ENABLED=true

INTELLIGENCE_REFRESH_MINUTES=5

INTELLIGENCE_LLM_BUDGET_PER_CYCLE=0.10

# NewsAPI.org headlines (only when NEWS_API_SOURCE=newsapi)
NEWS_API_KEY=

# News source: fixture | newsapi | jblanked | rapidapi_yahoo
# In live mode, auto-selects rapidapi_yahoo when RAPIDAPI_KEY is set (unless overridden)
NEWS_API_SOURCE=rapidapi_yahoo

# JBlanked News API — https://www.jblanked.com/news/api/docs/
# Auth header: Authorization: Api-Key YOUR_API_KEY (User-Agent required — Cloudflare blocks default Python)
JBLANKED_API_KEY=
# Data source: mql5 | forex-factory | fxstreet
JBLANKED_NEWS_SOURCE=mql5
# Optional override for HTTP User-Agent (default: QuantAI/1.0)
# JBLANKED_USER_AGENT=QuantAI/1.0 (Model-To-Market; Python)

# RapidAPI — competition intelligence (news, calendar, macro cash-flow context)
# Redeem key at https://rapidapi.com — used for context/gating only, never pricing
RAPIDAPI_KEY=
RAPIDAPI_YAHOO_HOST=yahoo-finance166.p.rapidapi.com
RAPIDAPI_YAHOO_REGION=US
RAPIDAPI_YAHOO_SNIPPET_COUNT=500
RAPIDAPI_FOREX_FACTORY_HOST=forex-factory-scraper1.p.rapidapi.com
RAPIDAPI_FOREX_FACTORY_TIMEZONE=GMT-06:00 Central Time (US & Canada)
RAPIDAPI_FOREX_FACTORY_TIME_FORMAT=12h
RAPIDAPI_FINANCE_HOST=real-time-finance-data.p.rapidapi.com
RAPIDAPI_FINANCE_ENABLED=true
RAPIDAPI_FINANCE_CASH_FLOW_SYMBOL=AAPL:NASDAQ
RAPIDAPI_FINANCE_CASH_FLOW_PERIOD=QUARTERLY
RAPIDAPI_NEWS=true
RAPIDAPI_CALENDAR=true

# Calendar: fixture | cache | jblanked | rapidapi_forex_factory
# In live mode, auto-selects rapidapi_forex_factory when RAPIDAPI_KEY is set
CALENDAR_SOURCE=rapidapi_forex_factory

FEAR_GREED_ENABLED=true

MACRO_FRED_API_KEY=

SENTIMENT_AGENT_ENABLED=true

EVENT_RISK_GATE_ENABLED=true

COMPETITION_LEADERBOARD_URL=

# Competition return baseline for dashboard + peer sizing: platform ($1M official) or session (live equity)
ROUND_EQUITY_BASELINE=platform

# Competition live: disable mock peers (neutral adj on fetch failure). Simulation may use mock.

PEER_MONITOR_MOCK=false

# When live leaderboard fetch fails (PEER_MONITOR_MOCK=false): mock | neutral

PEER_MONITOR_FALLBACK=neutral



# Operator watchdog (scripts/operator_watchdog.py — also auto-starts with live + dashboard)

OPERATOR_WATCHDOG_ENABLED=true

OPERATOR_WATCHDOG_INTERVAL_SEC=60

OPERATOR_DASHBOARD_URL=http://127.0.0.1:8080

OPERATOR_EQUITY_TOLERANCE_PCT=0.5

# Alerts: YELLOW and RED by default (log file + Logfire)

OPERATOR_ALERT_MIN_STATUS=YELLOW

OPERATOR_ALERT_DEDUPE_MINUTES=15

OPERATOR_ALERT_LOG=true

OPERATOR_ALERT_LOGFIRE=true

# Optional: Discord/Slack/generic webhook JSON POST

OPERATOR_ALERT_WEBHOOK=

OPERATOR_ALERT_NOTION=false

OPERATOR_ZMQ_ONLY=false

